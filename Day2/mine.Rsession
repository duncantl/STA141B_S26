[47:59] 103> unlist(g[, -(1:3)])
*** output flushed ***
[52:43] 104> fns
$readFile
function(f, lines = readLines(f))
{
    gr = getGrid(lines)
    lon = getLongitude(lines)
    date = getDate(lines)
    ans = data.frame(value = unlist(gr[, -(1:3)]))
    ans$lat = rep(gr[, 1], length(lon))
    ans$lon = rep(lon, each = nrow(gr))
    ans$date = date
    ans    
}
<environment: 0x111f05e28>

$getDate
function(x)    
{
    # Could use a regular expression to get the date value - module 2
    # Or keep the 00:00 and use strptime() and then as.Date()
    txt = strsplit(strsplit(x[5], ": ")[[1]][2], " ")[[1]][1]
    as.Date( strptime(txt, "%d-%b-%Y"))
}
<environment: 0x111f05e28>

$getLongitude
function(txt)
{
    # could do this better with regular expressions - module 2 of course.
    # For now, do it more directly.
    els = strsplit(txt[6], " ")[[1]]
    els = els[ els != "" ]
    # We'll deal with the W later.
    els
}
<environment: 0x111f05e28>

$getGrid
function(txt)
{
    read.table(textConnection(txt), skip = 7, header = FALSE)    
}
<environment: 0x111f05e28>

$getLatitude
function(lines)
{
    e = strsplit(lines[ - (1:7) ], " ")
    sapply(e, `[`, 2)
}
<environment: 0x111f05e28>

